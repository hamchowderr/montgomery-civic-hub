{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "montgomery-civic-hub.vercel.app"
        }
      ],
      "destination": "https://montgomery-civichub.otakusolutions.io/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/_mintlify/:path*",
      "destination": "https://otakusolutions.mintlify.app/_mintlify/:path*"
    },
    {
      "source": "/api/request",
      "destination": "https://otakusolutions.mintlify.app/_mintlify/api/request"
    },
    {
      "source": "/docs",
      "destination": "https://otakusolutions.mintlify.app/docs"
    },
    {
      "source": "/docs/llms.txt",
      "destination": "https://otakusolutions.mintlify.app/llms.txt"
    },
    {
      "source": "/docs/llms-full.txt",
      "destination": "https://otakusolutions.mintlify.app/llms-full.txt"
    },
    {
      "source": "/docs/sitemap.xml",
      "destination": "https://otakusolutions.mintlify.app/sitemap.xml"
    },
    {
      "source": "/docs/robots.txt",
      "destination": "https://otakusolutions.mintlify.app/robots.txt"
    },
    {
      "source": "/docs/mcp",
      "destination": "https://otakusolutions.mintlify.app/mcp"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://otakusolutions.mintlify.app/docs/:path*"
    },
    {
      "source": "/mintlify-assets/:path+",
      "destination": "https://otakusolutions.mintlify.app/mintlify-assets/:path+"
    }
  ]
}
